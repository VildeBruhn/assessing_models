c(NA, 1, 1, 1, 2, 2, 2, NA),
c(NA, NA, NA, NA, NA, NA, NA, NA),
c(NA, 3, 3, 4, 4, 5, 5, NA),
c(NA, NA, NA, NA, NA, NA, NA, NA))
)
ggsave("./results_paleoTS_v0.6.1/plot/dataset_uni_v3.pdf", plot_dataset_display,
width = 9, height = 6, units = "in", dpi = 300)
