OU_mov_opt_anc <- lapply(OU_mov_opt_anc, function(x) { x[[10]] <- NULL; x })
OU_mov_opt_anc<- lapply(OU_mov_opt_anc, function(x) {
as.paleoTS(mm = x$mm, vv = x$vv, nn = x$nn, tt = x$tt)
})
OU_mov_opt <- Filter(function(x) x[[10]] == 9, data_aicc)
