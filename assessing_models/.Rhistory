bird     = "#DB6000",
conodont = "#F07C26",
fish      = "#FF983D"
)
plot_dataset %>%
filter(!is.na(taxa)) %>%
count(taxa, name = "n") %>%
mutate(
fraction = n / sum(n),
pct = percent(fraction),
ypos = cumsum(fraction) - fraction/2
) -> df_taxa
