# Protists
foraminifer = "#598B8C",
coccolith    = "#719EA0",
radiolarian  = "#99C0C2",
diatom       = "#BFE0E1",
# Invertebrates
bryozoan    = "#968F2C",
bivalve     = "#A89F33",
gastropod   = "#B7AF3B",
cephalopod  = "#C6BF43",
ostracod    = "#DCCB4E",
