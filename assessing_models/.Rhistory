x$mm <- rev(x$mm)
x$vv <- rev(x$vv)
x$nn <- rev(x$nn)
x$tt <- rev(x$tt)
for (i in 1:length(x$tt)){
x$tt[i] <- 1 - x$tt[i]
}
return(x)
})
