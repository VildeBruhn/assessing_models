obs.slope.test <- slope.test(x, tt, model = "stasis", theta = theta)
bootstrap.matrix <- matrix(data = NA, nrow = nrep, ncol = 1)
x.sim <- sim.Stasis(ns = length(x), theta = theta, omega = omega,
