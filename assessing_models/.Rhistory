taxa_levels <- c(
"foraminifer", "coccolith", "radiolarian", "diatom",
"bryozoan", "bivalve", "gastropod", "cephalopod", "ostracod", "brachiopod", "trilobite", "graptolite",
"mammal", "bird", "conodont", "fish"
)
